{
  "name": "beacon-monorepo",
  "private": true,
  "scripts": {
    "bootstrap": "npm-run-all install:*",
    "install:backend": "cd backend && pnpm install",
    "install:frontend": "cd frontend && pnpm install",
    "install:launcher": "cd launcher && pnpm install",
    "dev": "cd launcher && pnpm dev",
    "dev:web": "concurrently \"cd backend && pnpm dev\" \"cd frontend && pnpm dev\"",
    "build": "cd launcher && pnpm build",
    "test": "npm-run-all test:backend test:frontend",
    "test:backend": "cd backend && pnpm test",
    "test:frontend": "cd frontend && pnpm test",
    "test:watch": "concurrently \"pnpm test:backend:watch\" \"pnpm test:frontend:watch\"",
    "test:backend:watch": "cd backend && pnpm test:watch",
    "test:frontend:watch": "cd frontend && pnpm test:watch",
    "lint": "cd frontend && pnpm lint",
    "lint:fix": "cd frontend && pnpm lint --fix",
    "check": "pnpm lint && pnpm test",
    "clean": "rm -rf node_modules backend/node_modules frontend/node_modules launcher/node_modules launcher/dist frontend/dist",
    "reset": "pnpm clean && pnpm install && pnpm bootstrap"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.2"
  },
  "version": "1.0.0",
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  }
}
